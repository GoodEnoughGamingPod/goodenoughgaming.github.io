---
import { getCollection } from "astro:content";
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SubscribeBar from '../components/SubscribeBar.astro';
import BlogCard from '../components/BlogCard.astro';
import SubscribeWidget from '../components/SubscribeWidget.astro';

const allPosts = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const latestPosts = allPosts.slice(0, 3);
---

<Layout title="Good Enough Gaming">	
	<Nav />
	<body >
		<div class="banner-section">
		 	<div class="absolute bottom-0 left-0 right-0 top-0 h-lvh w-full bg-[url('/GegBannerNoText.png')] bg-cover bg-[50%] banner" />
			<div class="title">
				<span class="title-good">GOOD ENOUGH</span>
				<span class="title-gaming">GAMING</span>
				<span class="title-podcast">PODCAST</span>
			</div>
			<p class="tagline">Just 4 dudes who love to talk about all things video games. New episodes every week.</p>
			<div class="alien-container" aria-hidden="true">
				<span class="alien"></span>
			</div>
			<div class="squid-container" aria-hidden="true">
				<span class="squid"></span>
			</div>
			<div class="octopus-container" aria-hidden="true">
				<span class="octopus"></span>
			</div>
			<div class="crab-teal-container" aria-hidden="true">
				<span class="crab-teal"></span>
			</div>
			<div class="squid-yellow-container" aria-hidden="true">
				<span class="squid-yellow"></span>
			</div>
			<div class="octopus-orange-container" aria-hidden="true">
				<span class="octopus-orange"></span>
			</div>
			<div class="listen-cards">
				<a href="https://open.spotify.com/show/3x1nEjDu2Y0ce19FGTXPyo" class="listen-badge" target="_blank" rel="noopener">
					<img src="/spotify_button.png" alt="Listen on Spotify" />
				</a>
				<a href="https://podcasts.apple.com/ca/podcast/good-enough-gaming-pod/id1553128355" class="listen-badge" target="_blank" rel="noopener">
					<img src="/apple_button.png" alt="Listen on Apple Podcasts" />
				</a>
				<a href="https://www.youtube.com/@GoodEnoughGamingPod" class="listen-badge" target="_blank" rel="noopener">
					<img src="/youtube_button.png" alt="Watch on YouTube" />
				</a>
			</div>
		</div>
		<div class="page-lower">
	<div class="synthwave-bg" aria-hidden="true">
		<svg viewBox="0 0 1440 1200" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
			<!-- Perspective horizon grid — horizontal lines, purple -->
			<line x1="0" y1="280" x2="1440" y2="280" stroke="#a855f7" stroke-width="1.2" opacity="0.22"/>
			<line x1="0" y1="370" x2="1440" y2="370" stroke="#a855f7" stroke-width="1.1" opacity="0.20"/>
			<line x1="0" y1="470" x2="1440" y2="470" stroke="#a855f7" stroke-width="1.0" opacity="0.19"/>
			<line x1="0" y1="585" x2="1440" y2="585" stroke="#a855f7" stroke-width="1.0" opacity="0.18"/>
			<line x1="0" y1="720" x2="1440" y2="720" stroke="#a855f7" stroke-width="0.9" opacity="0.16"/>
			<line x1="0" y1="880" x2="1440" y2="880" stroke="#a855f7" stroke-width="0.9" opacity="0.14"/>
			<line x1="0" y1="1070" x2="1440" y2="1070" stroke="#a855f7" stroke-width="0.8" opacity="0.12"/>
			<!-- Perspective rays from vanishing point (720, 280) — cyan -->
			<line x1="720" y1="280" x2="0"    y2="1200" stroke="#4ddbff" stroke-width="0.9" opacity="0.13"/>
			<line x1="720" y1="280" x2="240"  y2="1200" stroke="#4ddbff" stroke-width="0.9" opacity="0.13"/>
			<line x1="720" y1="280" x2="480"  y2="1200" stroke="#4ddbff" stroke-width="0.9" opacity="0.13"/>
			<line x1="720" y1="280" x2="720"  y2="1200" stroke="#4ddbff" stroke-width="0.9" opacity="0.13"/>
			<line x1="720" y1="280" x2="960"  y2="1200" stroke="#4ddbff" stroke-width="0.9" opacity="0.13"/>
			<line x1="720" y1="280" x2="1200" y2="1200" stroke="#4ddbff" stroke-width="0.9" opacity="0.13"/>
			<line x1="720" y1="280" x2="1440" y2="1200" stroke="#4ddbff" stroke-width="0.9" opacity="0.13"/>
			<line x1="720" y1="280" x2="0"    y2="750"  stroke="#4ddbff" stroke-width="0.7" opacity="0.10"/>
			<line x1="720" y1="280" x2="1440" y2="750"  stroke="#4ddbff" stroke-width="0.7" opacity="0.10"/>
			<line x1="720" y1="280" x2="0"    y2="530"  stroke="#4ddbff" stroke-width="0.7" opacity="0.10"/>
			<line x1="720" y1="280" x2="1440" y2="530"  stroke="#4ddbff" stroke-width="0.7" opacity="0.10"/>
			<!-- Major diagonal accents -->
			<line x1="0"    y1="80"   x2="1200" y2="1200" stroke="#4ddbff" stroke-width="1.5" opacity="0.18"/>
			<line x1="1440" y1="40"   x2="120"  y2="1200" stroke="#ff6ec7" stroke-width="1.5" opacity="0.17"/>
			<line x1="0"    y1="580"  x2="1440" y2="920"  stroke="#00d4aa" stroke-width="1.2" opacity="0.16"/>
			<line x1="1440" y1="350"  x2="0"    y2="700"  stroke="#ffd93d" stroke-width="1.0" opacity="0.14"/>
			<!-- Large diamond outline — pink -->
			<polygon points="720,30 1160,600 720,1170 280,600" fill="none" stroke="#ff6ec7" stroke-width="1.2" opacity="0.14"/>
			<!-- Corner triangles -->
			<polygon points="0,0 520,0 0,480"            fill="none" stroke="#a855f7" stroke-width="1.1" opacity="0.14"/>
			<polygon points="1440,550 1440,1200 820,1200" fill="none" stroke="#4ddbff" stroke-width="1.1" opacity="0.14"/>
			<!-- Scattered short accent lines -->
			<line x1="60"   y1="880" x2="340" y2="680" stroke="#ffd93d" stroke-width="1.0" opacity="0.18"/>
			<line x1="1080" y1="180" x2="1400" y2="420" stroke="#00d4aa" stroke-width="1.0" opacity="0.16"/>
			<line x1="180"  y1="360" x2="80"   y2="680" stroke="#ff6ec7" stroke-width="0.9" opacity="0.16"/>
		</svg>
	</div>
	<div class="images-section">
			<div class="banner-content-right">
				<h2 class="section-heading">Latest Episodes</h2>
				<div class="youtube-wrapper grid lg:grid-cols-3 sm:grid-cols-1">
					<div class="youtube-vid align-middle">
						<iframe class="youtube-iframe" src="https://www.youtube.com/embed?listType=playlist&list=UULFaKEZQ3_U67UWC9O2J0FsgQ"></iframe>
					</div>
					<div class="youtube-vid">
						<iframe class="youtube-iframe" src="https://www.youtube.com/embed?listType=playlist&list=UULFaKEZQ3_U67UWC9O2J0FsgQ&index=2"></iframe>
					</div>
					<div class="youtube-vid">
						<iframe class="youtube-iframe" src="https://www.youtube.com/embed?listType=playlist&list=UULFaKEZQ3_U67UWC9O2J0FsgQ&index=3"></iframe>
					</div>
				</div>
			</div>
		</div>
	<main>
		<h2 class="section-heading section-heading--news">Latest News</h2>
		<div class="news-wrapper grid lg:grid-cols-3 sm:grid-cols-1">
			{latestPosts.map((post) => (
				<BlogCard
					title={post.data.title}
					description={post.data.description}
					pubDate={post.data.pubDate}
					author={post.data.author}
					image={post.data.image}
					tags={post.data.tags}
					slug={post.slug}
				/>
			))}
		</div>
		<div class="view-all">
			<a href="/blog/" class="view-all-link">View All Posts &rarr;</a>
		</div>
	</main>

	<div class="community-links">
		<!-- Discord pair: HTML order [button][alien] → mobile=row(btn left, alien right), desktop=row-reverse(alien left, btn right) -->
		<div class="community-pair">
			<a href="https://discord.gg/PkNqmbCV" class="community-btn" target="_blank" rel="noopener">
				<img src="/discord.webp" alt="Join our Discord" />
			</a>
			<div class="comm-alien-wrap" aria-hidden="true">
				<span class="comm-alien comm-alien--pink"></span>
			</div>
		</div>
		<!-- Patreon pair: HTML order [alien][button] → mobile=row(alien left, btn right), desktop=row-reverse(btn left, alien right) -->
		<div class="community-pair">
			<div class="comm-alien-wrap" aria-hidden="true">
				<span class="comm-alien comm-alien--orange"></span>
			</div>
			<a href="https://patreon.com/GoodEnoughGamingPodcast" class="community-btn" target="_blank" rel="noopener">
				<img src="/patreon.webp" alt="Support on Patreon" />
			</a>
		</div>
	</div>

	<div class="hosts-section">
		<h2 class="section-heading section-heading--hosts">Meet the Hosts</h2>
		<img class="group-image-large" src="groupPhoto.PNG" alt="Good Enough Gaming crew" />
		<div class="hosts-grid">
			<div class="host-tile host-tile--cyan"><span class="host-name">Kyle</span></div>
			<div class="host-tile host-tile--pink"><span class="host-name">Jordan</span></div>
			<div class="host-tile host-tile--purple"><span class="host-name">Darrell</span></div>
			<div class="host-tile host-tile--teal"><span class="host-name">Trevor</span></div>
		</div>
		<a href="/about/" class="learn-more-btn">Learn More</a>
	</div>

	<div class="subscribe-wrap">
		<SubscribeWidget />
	</div>

	</div> <!-- end .page-lower -->

	<Footer />
	</body>
</Layout>

<style>
	@import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Monoton&family=Raleway:ital,wght@1,300&display=swap');

	body {
		position: relative;
		min-height: 100%;
		width: 100%;
		background-attachment: fixed;
		margin: 0;
		padding: 0;
	}
	main {
		margin: auto;
		padding: 1rem;
		max-width: 90rem;		
		color: white;
		font-size: 20px;
		line-height: 1.6;
		margin-top: 2rem;
	}
	
	.banner-section {
		position: relative;
		height: 100vh;
		overflow: hidden;
	}
	.group-image {
		width: 100%;
		height: auto;
		object-fit: contain;
	}
	
	.title {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		margin-left: auto;
		margin-right: auto;
		margin-top: 12rem;
		z-index: 1;
		font-family: 'Press Start 2P', 'Courier New', monospace;
	}
	.title-good {
		display: block;
		font-size: 3.1rem;
		color: #4ddbff;
		-webkit-text-stroke: 2px #000;
		paint-order: stroke fill;
		text-shadow:
			/* 3D extrusion — 8 layers going down-right */
			1px 1px 0 #003344,
			2px 2px 0 #002a38,
			3px 3px 0 #00222e,
			4px 4px 0 #001a24,
			5px 5px 0 #00121a,
			6px 6px 0 #000a10,
			7px 7px 0 #000508,
			8px 8px 6px rgba(0,0,0,0.8),
			/* outer glow */
			0 0 20px #4ddbff,
			0 0 50px #4ddbff,
			0 0 90px #df53f5;
		line-height: 1.5;
		letter-spacing: 0.05em;
	}
	.title-gaming {
		display: block;
		font-size: 5.9rem;
		color: #df53f5;
		-webkit-text-stroke: 2px #000;
		paint-order: stroke fill;
		text-shadow:
			/* 3D extrusion — 8 layers going down-right */
			1px 1px 0 #3a0044,
			2px 2px 0 #300038,
			3px 3px 0 #26002c,
			4px 4px 0 #1c0020,
			5px 5px 0 #120014,
			6px 6px 0 #08000a,
			7px 7px 0 #040006,
			8px 8px 6px rgba(0,0,0,0.8),
			/* outer glow */
			0 0 20px #df53f5,
			0 0 50px #df53f5,
			0 0 90px #4ddbff;
		line-height: 1.3;
		letter-spacing: 0.05em;
	}
	.title-podcast {
		display: inline-block;
		font-size: 3.5rem;
		font-family: 'Monoton', cursive;
		color: #ff6ec7;
		transform: rotate(-5deg);
		margin-top: 1.8rem;
		letter-spacing: 0.15em;
		animation: neon-flicker 5s infinite;
	}

	@keyframes neon-flicker {
		0%, 17%, 19%, 21%, 55%, 57%, 59%, 100% {
			opacity: 1;
			text-shadow:
				0 0 5px #fff,
				0 0 10px #fff,
				0 0 20px #ff6ec7,
				0 0 40px #ff6ec7,
				0 0 70px #df53f5,
				0 0 100px #df53f5;
		}
		18%, 56% {
			opacity: 0.2;
			text-shadow: none;
		}
		20%, 58% {
			opacity: 0.8;
			text-shadow:
				0 0 5px #fff,
				0 0 15px #ff6ec7,
				0 0 30px #ff6ec7;
		}
	}
	.astro-a {
		position: absolute;
		top: -32px;
		left: 50%;
		transform: translatex(-50%);
		width: 220px;
		height: auto;
		z-index: -1;
	}
	.instructions {
		margin-bottom: 2rem;
		border: 1px solid rgba(var(--accent-light), 25%);
		background: linear-gradient(rgba(var(--accent-dark), 66%), rgba(var(--accent-dark), 33%));
		padding: 0.5rem;
		border-radius: 8px;
		margin-top: 3rem;
	}
	.instructions code {
		font-size: 0.8em;
		font-weight: bold;
		background: rgba(var(--accent-light), 12%);
		color: rgb(var(--accent-light));
		border-radius: 4px;
		padding: 0.3em 0.4em;
	}
	.instructions strong {
		color: rgb(var(--accent-light));
	}
	.link-card-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(24ch, 1fr));
		gap: 2rem;
		padding: 0;
	}

	.listen-cards {
		position: absolute;
		bottom: 2rem;
		left: 0;
		right: 0;
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 1.5rem;
		padding: 0 1rem;
		flex-wrap: wrap;
		z-index: 2;
	}

	.tagline {
		position: relative;
		z-index: 1;
		text-align: center;
		font-family: 'Raleway', sans-serif;
		font-style: italic;
		font-weight: 300;
		font-size: 0.95rem;
		color: rgba(255, 255, 255, 0.82);
		letter-spacing: 0.04em;
		margin-top: 1.5rem;
		padding: 0 2rem;
	}

	.page-lower {
		position: relative;
		isolation: isolate;
	}
	.synthwave-bg {
		position: absolute;
		inset: 0;
		z-index: -1;
		pointer-events: none;
		overflow: hidden;
	}
	.synthwave-bg svg {
		width: 100%;
		height: 100%;
	}

	.images-section {
		display: flex;
		flex-direction: row;
		justify-content: center;
		align-items: flex-start;
		gap: 2rem;
		padding: 3rem 2rem;
	}
	.group-photo-section {
		background: #13151a;
		display: flex;
		justify-content: center;
		padding: 2rem;
	}
	.group-photo-section .group-image {
		max-width: 600px;
		width: 100%;
		height: auto;
		border-radius: 8px;
	}

	.listen-badge img {
		height: 5rem;
		width: auto;
		display: block;
		transition: transform 0.2s ease, opacity 0.2s ease;
	}

	.listen-badge:hover img {
		transform: translateY(-3px);
		opacity: 0.85;
	}

	.section-heading {
		font-family: 'Press Start 2P', 'Courier New', monospace;
		font-size: 1.8rem;
		color: #ff8c00;
		text-align: center;
		margin-top: 0;
		margin-bottom: 2.5rem;
		text-shadow:
			1px 1px 0 #7a3800,
			2px 2px 0 #6a2e00,
			3px 3px 0 #5a2400,
			4px 4px 0 #4a1a00,
			5px 5px 8px rgba(0,0,0,0.7),
			0 0 20px #ff8c00,
			0 0 50px #ff6500,
			0 0 90px #ff4500;
	}
	.section-heading--news {
		color: #ff6ec7;
		text-shadow:
			1px 1px 0 #7a0044,
			2px 2px 0 #6a0038,
			3px 3px 0 #5a002c,
			4px 4px 0 #4a0020,
			5px 5px 8px rgba(0,0,0,0.7),
			0 0 20px #ff6ec7,
			0 0 50px #df53f5,
			0 0 90px #a855f7;
	}
	.section-heading--hosts {
		color: #00d4aa;
		text-shadow:
			1px 1px 0 #003328,
			2px 2px 0 #002820,
			3px 3px 0 #001d18,
			4px 4px 0 #001210,
			5px 5px 8px rgba(0,0,0,0.7),
			0 0 20px #00d4aa,
			0 0 50px #00ffcc,
			0 0 90px #00bfaa;
	}

	/* ---- Community links (desktop) ---- */
	.community-links {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 4rem;
		padding: 4rem 1rem;
		position: relative;
		z-index: 1;
	}
	.community-pair {
		display: flex;
		flex-direction: row-reverse; /* desktop: flips each pair so alien is on outer edge */
		align-items: center;
		gap: 1.5rem;
	}
	.community-btn img {
		height: 5rem;
		width: auto;
		display: block;
		transition: transform 0.2s ease, opacity 0.2s ease;
	}
	.community-btn:hover img {
		transform: translateY(-3px);
		opacity: 0.85;
	}
	/* Community alien containers */
	.comm-alien-wrap {
		width: 110px;
		height: 80px;
		flex-shrink: 0;
		position: relative;
	}
	.comm-alien {
		display: block;
		width: 10px;
		height: 10px;
		background: transparent;
	}
	.comm-alien--pink {
		animation: comm-pink-walk 0.8s steps(1) infinite;
		filter: drop-shadow(0 0 6px #ff6ec7);
	}
	.comm-alien--orange {
		animation: comm-orange-walk 0.8s steps(1) infinite;
		filter: drop-shadow(0 0 6px #ff8c42);
	}

	/* Pink invader (crab shape, #ff6ec7) */
	@keyframes comm-pink-walk {
		0%, 100% { box-shadow:
			20px 0 0 0 #ff6ec7, 80px 0 0 0 #ff6ec7,
			30px 10px 0 0 #ff6ec7, 70px 10px 0 0 #ff6ec7,
			20px 20px 0 0 #ff6ec7, 30px 20px 0 0 #ff6ec7, 40px 20px 0 0 #ff6ec7, 50px 20px 0 0 #ff6ec7, 60px 20px 0 0 #ff6ec7, 70px 20px 0 0 #ff6ec7, 80px 20px 0 0 #ff6ec7,
			10px 30px 0 0 #ff6ec7, 20px 30px 0 0 #ff6ec7, 40px 30px 0 0 #ff6ec7, 50px 30px 0 0 #ff6ec7, 60px 30px 0 0 #ff6ec7, 80px 30px 0 0 #ff6ec7, 90px 30px 0 0 #ff6ec7,
			0 40px 0 0 #ff6ec7, 10px 40px 0 0 #ff6ec7, 20px 40px 0 0 #ff6ec7, 30px 40px 0 0 #ff6ec7, 40px 40px 0 0 #ff6ec7, 50px 40px 0 0 #ff6ec7, 60px 40px 0 0 #ff6ec7, 70px 40px 0 0 #ff6ec7, 80px 40px 0 0 #ff6ec7, 90px 40px 0 0 #ff6ec7, 100px 40px 0 0 #ff6ec7,
			0 50px 0 0 #ff6ec7, 20px 50px 0 0 #ff6ec7, 30px 50px 0 0 #ff6ec7, 40px 50px 0 0 #ff6ec7, 50px 50px 0 0 #ff6ec7, 60px 50px 0 0 #ff6ec7, 70px 50px 0 0 #ff6ec7, 80px 50px 0 0 #ff6ec7, 100px 50px 0 0 #ff6ec7,
			0 60px 0 0 #ff6ec7, 20px 60px 0 0 #ff6ec7, 80px 60px 0 0 #ff6ec7, 100px 60px 0 0 #ff6ec7,
			30px 70px 0 0 #ff6ec7, 40px 70px 0 0 #ff6ec7, 60px 70px 0 0 #ff6ec7, 70px 70px 0 0 #ff6ec7;
		}
		50% { box-shadow:
			20px 0 0 0 #ff6ec7, 80px 0 0 0 #ff6ec7,
			0 10px 0 0 #ff6ec7, 30px 10px 0 0 #ff6ec7, 70px 10px 0 0 #ff6ec7, 100px 10px 0 0 #ff6ec7,
			0 20px 0 0 #ff6ec7, 20px 20px 0 0 #ff6ec7, 30px 20px 0 0 #ff6ec7, 40px 20px 0 0 #ff6ec7, 50px 20px 0 0 #ff6ec7, 60px 20px 0 0 #ff6ec7, 70px 20px 0 0 #ff6ec7, 80px 20px 0 0 #ff6ec7, 100px 20px 0 0 #ff6ec7,
			0 30px 0 0 #ff6ec7, 10px 30px 0 0 #ff6ec7, 20px 30px 0 0 #ff6ec7, 40px 30px 0 0 #ff6ec7, 50px 30px 0 0 #ff6ec7, 60px 30px 0 0 #ff6ec7, 80px 30px 0 0 #ff6ec7, 90px 30px 0 0 #ff6ec7, 100px 30px 0 0 #ff6ec7,
			0 40px 0 0 #ff6ec7, 10px 40px 0 0 #ff6ec7, 20px 40px 0 0 #ff6ec7, 30px 40px 0 0 #ff6ec7, 40px 40px 0 0 #ff6ec7, 50px 40px 0 0 #ff6ec7, 60px 40px 0 0 #ff6ec7, 70px 40px 0 0 #ff6ec7, 80px 40px 0 0 #ff6ec7, 90px 40px 0 0 #ff6ec7, 100px 40px 0 0 #ff6ec7,
			10px 50px 0 0 #ff6ec7, 20px 50px 0 0 #ff6ec7, 30px 50px 0 0 #ff6ec7, 40px 50px 0 0 #ff6ec7, 50px 50px 0 0 #ff6ec7, 60px 50px 0 0 #ff6ec7, 70px 50px 0 0 #ff6ec7, 80px 50px 0 0 #ff6ec7, 90px 50px 0 0 #ff6ec7,
