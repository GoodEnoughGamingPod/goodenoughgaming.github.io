---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await post.render();

const formattedDate = post.data.pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Layout title={`${post.data.title} — Good Enough Gaming`}>
  <Nav />
  <body>
    <main>
      <a href="/blog/" class="back-link">&larr; Back to Blog</a>
      <article class="post">
        {post.data.image?.url && (
          <img
            src={post.data.image.url}
            alt={post.data.image.alt || post.data.title}
            class="hero-image"
          />
        )}
        <h1 class="post-title">{post.data.title}</h1>
        <p class="post-meta">
          <span class="post-date">{formattedDate}</span> &bull; {post.data.author}
        </p>
        {post.data.tags && post.data.tags.length > 0 && (
          <div class="post-tags">
            {post.data.tags.map((tag: string) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
        <div class="prose">
          <Content />
        </div>
      </article>
    </main>
    <Footer />
  </body>
</Layout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&display=swap');

  body {
    min-height: 100vh;
    background: #13151a;
  }
  main {
    margin: 0 auto;
    padding: 1rem;
    max-width: 50rem;
    color: white;
    margin-top: 8rem;
  }
  .back-link {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 600;
    color: #4ddbff;
    text-decoration: none;
    font-size: 1rem;
    letter-spacing: 0.04em;
    display: inline-block;
    margin-bottom: 1.5rem;
  }
  .back-link:hover {
    text-decoration: underline;
  }
  .post {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .hero-image {
    width: 100%;
    border-radius: 8px;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }
  .post-title {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 2.5rem;
    color: #4ddbff;
    margin: 0;
    line-height: 1.1;
    letter-spacing: 0.03em;
  }
  .post-meta {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 500;
    font-size: 1rem;
    opacity: 0.7;
    margin: 0;
  }
  .post-date {
    color: #a7a4e0;
  }
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .tag {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 600;
    font-size: 0.85rem;
    padding: 0.1rem 0.55rem;
    background-color: rgba(167, 164, 224, 0.2);
    color: #a7a4e0;
    border-radius: 4px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .prose {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 500;
    line-height: 1.8;
    font-size: 1.15rem;
  }
  .prose :global(h2) {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    color: #4ddbff;
    font-size: 1.7rem;
    margin-top: 2rem;
    letter-spacing: 0.04em;
  }
  .prose :global(h3) {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 600;
    color: #a7a4e0;
    font-size: 1.4rem;
    margin-top: 1.5rem;
    letter-spacing: 0.03em;
  }
  .prose :global(a) {
    color: #4ddbff;
  }
  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
  }
  .prose :global(li) {
    margin-bottom: 0.5rem;
  }
  .prose :global(blockquote) {
    font-style: italic;
    border-left: 3px solid #a7a4e0;
    padding-left: 1rem;
    margin-left: 0;
    opacity: 0.85;
  }
  @media (min-width: 64rem) {
    main {
      margin-top: 10rem;
    }
  }
</style>
