---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="Good Enough Gaming">
    <Nav />
    <body>
        <div class="page-wrap">
            <div class="container">
                <div class="contact-form-container">
                    <form id="form" action="https://api.web3forms.com/submit" method="POST" class="contact-form">
                        <span class="form-header">Contact Us</span>
                        <input type="hidden" name="access_key" value="1ecfa37-5db1-4fao-ab73-325d9a3944c5">
                        <input type="text" name="name" class="input" placeholder="Your Name" />
                        <input type="email" name="email" class="input" placeholder="Your Email" />
                        <textarea name="message" cols="30" rows="5" placeholder="Enter your message" class="input" required></textarea>
                        <button class="submit" type="submit">Submit</button>
                        <p id="result"></p>
                    </form>
                </div>
            </div>
        </div>
        <Footer />
    </body>
</Layout>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Raleway:wght@400;500;600&display=swap');

    body {
        min-height: 100vh;
        background: #13151a;
        display: flex;
        flex-direction: column;
    }

    .page-wrap {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8rem 1.5rem 4rem;
    }

    .container {
        background: #1c1c2e;
        border: 1px solid rgba(77, 219, 255, 0.15);
        border-radius: 20px;
        box-shadow:
            0 0 40px rgba(77, 219, 255, 0.06),
            0 8px 32px rgba(0, 0, 0, 0.4);
        width: 100%;
        max-width: 520px;
        padding: 3rem 2.5rem;
    }

    .contact-form-container {
        width: 100%;
    }

    .contact-form {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .form-header {
        font-family: 'Press Start 2P', monospace;
        font-size: 1.1rem;
        color: #4ddbff;
        text-align: center;
        display: block;
        margin-bottom: 0.75rem;
        text-shadow: 0 0 14px rgba(77, 219, 255, 0.5);
        letter-spacing: 0.05em;
    }

    .input {
        border: 1px solid rgba(167, 164, 224, 0.2);
        outline: none;
        background: #0d0d1a;
        color: #e8e6f0;
        padding: 0.85rem 1.1rem;
        border-radius: 8px;
        width: 100%;
        font-size: 1rem;
        font-family: 'Raleway', sans-serif;
        font-weight: 500;
        transition: border-color 0.2s, box-shadow 0.2s;
        box-sizing: border-box;
        resize: vertical;
    }

    .input:focus {
        border-color: #4ddbff;
        box-shadow: 0 0 10px rgba(77, 219, 255, 0.25);
    }

    ::placeholder {
        font-family: 'Raleway', sans-serif;
        color: #4a4870;
        opacity: 1;
    }

    .submit {
        border: none;
        outline: none;
        color: #04040e;
        width: 100%;
        padding: 0.9rem;
        background: #4ddbff;
        font-family: 'Press Start 2P', monospace;
        font-size: 0.75rem;
        letter-spacing: 0.05em;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.2s, box-shadow 0.2s, transform 0.15s;
        margin-top: 0.5rem;
    }

    .submit:hover {
        background: #80e8ff;
        box-shadow: 0 0 18px rgba(77, 219, 255, 0.5);
        transform: translateY(-2px);
    }
</style>

<script is:inline>
    const form = document.getElementById('form');
    const result = document.getElementById('result');

    form.addEventListener('submit', function(e) {
        const formData = new FormData(form);
        e.preventDefault();

        const object = Object.fromEntries(formData);
        const json = JSON.stringify(object);

        result.innerHTML = "Please wait..."

        fetch('https://api.web3forms.com/submit', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json'
                },
                body: json
            })
            .then(async (response) => {
                let json = await response.json();
                if (response.status == 200) {
                    result.innerHTML = json.message;
                } else {
                    console.log(response);
                    result.innerHTML = json.message;
                }
            })
            .catch(error => {
                console.log(error);
                result.innerHTML = "Something went wrong!";
            })
            .then(function() {
                form.reset();
                setTimeout(() => {
                    result.style.display = "none";
                }, 3000);
            });
    });
</script>
