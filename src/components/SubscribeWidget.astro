---
---

<section class="sub-scene-section">
  <div class="sub-scene">

    <!-- Monitor -->
    <div class="monitor-wrap">
      <div class="monitor">
        <div class="monitor-screen">
          <p class="sub-heading">Subscribe!</p>
          <form class="sub-form" onsubmit="handleSubscribe(event)">
            <input type="email" class="sub-input" placeholder="your@email.com" />
            <button type="submit" class="sub-btn">Go →</button>
          </form>
          <p class="sub-confirm" id="sub-confirm"></p>
        </div>
        <div class="monitor-chin">
          <div class="chin-led"></div>
        </div>
      </div>
      <div class="monitor-neck"></div>
      <div class="monitor-foot"></div>
    </div>

    <!-- Console + cord + controller -->
    <div class="console-row">

      <div class="console">
        <div class="console-slot">
          <div class="slot-inner"></div>
        </div>
        <div class="console-body">
          <div class="vent-group">
            <span></span><span></span><span></span><span></span>
          </div>
          <div class="console-controls">
            <div class="c-led"></div>
            <div class="c-btn"></div>
            <div class="c-btn"></div>
          </div>
        </div>
        <div class="cord-port"></div>
      </div>

      <!-- Wavy cord SVG -->
      <svg class="cord-svg" viewBox="0 0 200 80" xmlns="http://www.w3.org/2000/svg">
        <path
          d="M0,40 C35,40 35,12 72,12 C109,12 109,68 146,68 C168,68 180,40 200,40"
          stroke="#3a3a58"
          stroke-width="4"
          fill="none"
          stroke-linecap="round"
        />
        <!-- cord connector at console end -->
        <rect x="0" y="33" width="8" height="14" rx="2" fill="#2a2a42"/>
        <!-- cord connector at controller end -->
        <rect x="192" y="33" width="8" height="14" rx="2" fill="#2a2a42"/>
      </svg>

      <!-- Controller (SNES-inspired) -->
      <div class="controller">
        <div class="ctrl-body">

          <div class="dpad">
            <div class="dpad-h"></div>
            <div class="dpad-v"></div>
            <div class="dpad-center"></div>
          </div>

          <div class="ctrl-mid">
            <div class="mid-btn select"></div>
            <div class="mid-btn start"></div>
          </div>

          <div class="face-btns">
            <div class="f-btn btn-y"></div>
            <div class="f-btn btn-x"></div>
            <div class="f-btn btn-a"></div>
            <div class="f-btn btn-b"></div>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<script>
  function handleSubscribe(e: Event) {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const input = form.querySelector('input') as HTMLInputElement;
    const confirm = document.getElementById('sub-confirm');
    if (input.value && confirm) {
      confirm.textContent = '✓ You\'re in!';
      input.value = '';
    }
  }
  (window as any).handleSubscribe = handleSubscribe;
</script>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Raleway:wght@400;600&display=swap');

  .sub-scene-section {
    padding: 5rem 2rem 6rem;
    display: flex;
    justify-content: center;
  }

  .sub-scene {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ===== MONITOR ===== */
  .monitor-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .monitor {
    width: 620px;
    background: #1c1c2e;
    border: 10px solid #2d2d48;
    border-radius: 32px 32px 18px 18px;
    padding: 18px;
    box-shadow:
      0 0 30px rgba(77, 219, 255, 0.18),
      0 0 80px rgba(77, 219, 255, 0.08),
      inset 0 2px 0 rgba(255, 255, 255, 0.04);
  }

  .monitor-screen {
    background: #04040e;
    border-radius: 12px;
    min-height: 320px;
    padding: 48px 40px 36px;
    border: 3px solid #0e0e22;
    box-shadow:
      inset 0 0 60px rgba(77, 219, 255, 0.12),
      inset 0 0 120px rgba(168, 85, 247, 0.07);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 28px;
  }

  .monitor-chin {
    margin-top: 14px;
    height: 38px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .chin-led {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #4ddbff;
    box-shadow: 0 0 10px #4ddbff, 0 0 24px rgba(77, 219, 255, 0.5);
  }

  .monitor-neck {
    width: 55px;
    height: 58px;
    background: #2d2d48;
  }

  .monitor-foot {
    width: 260px;
    height: 22px;
    background: #2d2d48;
    border-radius: 0 0 14px 14px;
  }

  /* Subscribe form */
  .sub-heading {
    font-family: 'Press Start 2P', monospace;
    font-size: 1.7rem;
    color: #4ddbff;
    margin: 0;
    text-shadow: 0 0 14px #4ddbff, 0 0 36px rgba(77, 219, 255, 0.5);
    letter-spacing: 0.08em;
  }

  .sub-form {
    display: flex;
    gap: 12px;
    width: 100%;
  }

  .sub-input {
    flex: 1;
    background: #09091a;
    border: 2px solid #2a2a50;
    border-radius: 6px;
    color: #cac7ff;
    font-family: 'Raleway', sans-serif;
    font-size: 1.1rem;
    padding: 0.75rem 1.2rem;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .sub-input:focus {
    border-color: #4ddbff;
    box-shadow: 0 0 12px rgba(77, 219, 255, 0.3);
  }

  .sub-input::placeholder {
    color: #44446a;
  }

  .sub-btn {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.85rem;
    padding: 0.75rem 1.6rem;
    background: #4ddbff;
    color: #04040e;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    white-space: nowrap;
    letter-spacing: 0.05em;
    transition: background 0.2s, box-shadow 0.2s;
  }

  .sub-btn:hover {
    background: #80e8ff;
    box-shadow: 0 0 18px rgba(77, 219, 255, 0.55);
  }

  .sub-confirm {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.9rem;
    color: #00d4aa;
    margin: 0;
    min-height: 1.2em;
    text-shadow: 0 0 10px #00d4aa;
  }

  /* ===== CONSOLE ROW ===== */
  .console-row {
    display: flex;
    align-items: center;
  }

  /* ===== CONSOLE ===== */
  .console {
    width: 460px;
    height: 138px;
    background: #1c1c2e;
    border: 7px solid #2d2d48;
    border-radius: 18px;
    display: flex;
    align-items: center;
    padding: 0 18px 0 24px;
    gap: 22px;
    flex-shrink: 0;
    box-shadow:
      0 10px 36px rgba(0, 0, 0, 0.5),
      0 0 22px rgba(168, 85, 247, 0.10);
    position: relative;
  }

  /* Cartridge slot */
  .console-slot {
    width: 95px;
    height: 88px;
    background: #09090f;
    border: 3px solid #1e1e30;
    border-radius: 7px 7px 0 0;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 8px;
    flex-shrink: 0;
  }

  .slot-inner {
    width: 52px;
    height: 10px;
    background: #141428;
    border-radius: 3px;
  }

  .console-body {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 26px;
  }

  .vent-group {
    display: flex;
    gap: 9px;
  }

  .vent-group span {
    display: block;
    width: 6px;
    height: 60px;
    background: #111126;
    border-radius: 3px;
  }

  .console-controls {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 12px;
    margin-left: auto;
  }

  .c-led {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #ff6ec7;
    box-shadow: 0 0 10px #ff6ec7, 0 0 22px rgba(255, 110, 199, 0.5);
  }

  .c-btn {
    width: 48px;
    height: 15px;
    background: #252540;
    border: 2px solid #353558;
    border-radius: 5px;
  }

  /* Cord port nub on right side */
  .cord-port {
    width: 11px;
    height: 26px;
    background: #252540;
    border: 2px solid #353558;
    border-radius: 0 5px 5px 0;
    flex-shrink: 0;
  }

  /* ===== CORD ===== */
  .cord-svg {
    width: 260px;
    height: 120px;
    flex-shrink: 0;
    overflow: visible;
  }

  /* ===== CONTROLLER ===== */
  .controller {
    flex-shrink: 0;
    position: relative;
  }

  .ctrl-body {
    width: 320px;
    height: 112px;
    background: #1c1c2e;
    border: 6px solid #2d2d48;
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 26px;
    box-shadow: 0 10px 32px rgba(0, 0, 0, 0.5);
    position: relative;
  }

  /* Left grip */
  .ctrl-body::before {
    content: '';
    position: absolute;
    bottom: -33px;
    left: 22px;
    width: 95px;
    height: 40px;
    background: #1c1c2e;
    border: 6px solid #2d2d48;
    border-top: none;
    border-radius: 0 0 30px 30px;
  }

  /* Right grip */
  .ctrl-body::after {
    content: '';
    position: absolute;
    bottom: -33px;
    right: 22px;
    width: 95px;
    height: 40px;
    background: #1c1c2e;
    border: 6px solid #2d2d48;
    border-top: none;
    border-radius: 0 0 30px 30px;
  }

  /* D-pad */
  .dpad {
    position: relative;
    width: 70px;
    height: 70px;
    flex-shrink: 0;
  }

  .dpad-h, .dpad-v {
    position: absolute;
    background: #111126;
    border-radius: 3px;
  }

  .dpad-h {
    width: 70px;
    height: 24px;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
  }

  .dpad-v {
    width: 24px;
    height: 70px;
    left: 50%;
    top: 0;
    transform: translateX(-50%);
  }

  .dpad-center {
    position: absolute;
    width: 24px;
    height: 24px;
    background: #1a1a32;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  /* Start / Select */
  .ctrl-mid {
    display: flex;
    flex-direction: column;
    gap: 13px;
    flex-shrink: 0;
  }

  .mid-btn {
    width: 34px;
    height: 13px;
    border-radius: 5px;
    background: #252540;
    border: 2px solid #353558;
  }

  /* Face buttons — absolute diamond layout */
  .face-btns {
    position: relative;
    width: 76px;
    height: 76px;
    flex-shrink: 0;
  }

  .f-btn {
    position: absolute;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.12);
  }

  /* Top */
  .btn-y {
    top: 10%;
    left: 50%;
    transform: translateX(-50%);
    background: #ffd93d;
    box-shadow: 0 0 7px rgba(255, 217, 61, 0.7);
  }
  /* Left */
  .btn-x {
    top: 50%;
    left: 10%;
    transform: translateY(-50%);
    background: #4ddbff;
    box-shadow: 0 0 7px rgba(77, 219, 255, 0.7);
  }
  /* Right */
  .btn-a {
    top: 50%;
    right: 10%;
    transform: translateY(-50%);
    background: #ff6ec7;
    box-shadow: 0 0 7px rgba(255, 110, 199, 0.7);
  }
  /* Bottom */
  .btn-b {
    bottom: 10%;
    left: 50%;
    transform: translateX(-50%);
    background: #00d4aa;
    box-shadow: 0 0 7px rgba(0, 212, 170, 0.7);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1100px) {
    .monitor { width: 480px; }
    .console { width: 360px; height: 110px; }
    .console-slot { width: 74px; height: 70px; }
    .ctrl-body { width: 250px; height: 90px; }
    .cord-svg { width: 200px; height: 100px; }
  }

  @media (max-width: 760px) {
    .monitor { width: 310px; border-width: 6px; border-radius: 18px 18px 10px 10px; padding: 10px; }
    .monitor-screen { min-height: 200px; padding: 28px 18px; gap: 18px; }
    .sub-heading { font-size: 1rem; }
    .sub-input { font-size: 0.85rem; padding: 0.5rem 0.8rem; }
    .sub-btn { font-size: 0.55rem; padding: 0.5rem 0.9rem; }
    .monitor-neck { width: 32px; height: 36px; }
    .monitor-foot { width: 150px; height: 14px; }
    .console-row {
      flex-direction: column;
      align-items: center;
    }
    .console { width: 290px; height: 82px; border-width: 4px; gap: 14px; padding: 0 12px 0 14px; }
    .console-slot { width: 55px; height: 52px; }
    .vent-group span { height: 36px; width: 4px; }
    .c-btn { width: 30px; height: 10px; }
    .c-led { width: 10px; height: 10px; }
    .cord-port { width: 7px; height: 16px; }
    .cord-svg { transform: rotate(90deg); width: 90px; height: 130px; }
    .ctrl-body { width: 200px; height: 72px; border-width: 4px; padding: 0 16px; }
    .ctrl-body::before { width: 58px; height: 26px; bottom: -20px; left: 14px; border-width: 4px; }
    .ctrl-body::after  { width: 58px; height: 26px; bottom: -20px; right: 14px; border-width: 4px; }
    .dpad { width: 44px; height: 44px; }
    .dpad-h { width: 44px; height: 15px; }
    .dpad-v { width: 15px; height: 44px; }
    .dpad-center { width: 15px; height: 15px; }
    .mid-btn { width: 22px; height: 9px; }
    .face-btns { width: 54px; height: 54px; }
    .f-btn { width: 14px; height: 14px; }
  }
</style>
