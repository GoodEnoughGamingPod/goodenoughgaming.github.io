---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  author: string;
  image?: { url?: string; alt?: string };
  tags?: string[];
  slug: string;
}

const { title, description, pubDate, author, image, tags, slug } = Astro.props;
const formattedDate = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<a href={`/blog/${slug}/`} class="blog-card">
  {image?.url && (
    <img src={image.url} alt={image.alt || title} class="card-image" />
  )}
  <div class="card-content">
    <h3 class="card-title">{title}</h3>
    <p class="card-meta">
      <span class="card-date">{formattedDate}</span> &bull; {author}
    </p>
    <p class="card-description">{description}</p>
    {tags && tags.length > 0 && (
      <div class="card-tags">
        {tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}
  </div>
</a>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&display=swap');

  .blog-card {
    display: flex;
    flex-direction: column;
    background-color: #23262d;
    border-radius: 7px;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.1);
    text-decoration: none;
    color: white;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4), inset 0 0 0 1px rgba(77, 219, 255, 0.3);
  }
  .card-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }
  .card-content {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .card-title {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 1.35rem;
    margin: 0;
    color: #4ddbff;
    line-height: 1.2;
    letter-spacing: 0.03em;
  }
  .card-meta {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 500;
    font-size: 0.95rem;
    margin: 0;
    opacity: 0.7;
  }
  .card-date {
    color: #a7a4e0;
  }
  .card-description {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 500;
    font-size: 1.05rem;
    margin: 0;
    opacity: 0.85;
    line-height: 1.5;
  }
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.25rem;
  }
  .tag {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 600;
    font-size: 0.85rem;
    padding: 0.1rem 0.55rem;
    background-color: rgba(167, 164, 224, 0.2);
    color: #a7a4e0;
    border-radius: 4px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
</style>
