---
---

<div class="health-widget">
  <div class="widget-inner">
    <p class="widget-name">GOOD ENOUGH</p>
    <div class="hp-row">
      <span class="hp-label">HP</span>
      <div class="hearts">
        <span class="heart heart--full"></span>
        <span class="heart heart--full"></span>
        <span class="heart heart--full"></span>
        <span class="heart heart--empty"></span>
        <span class="heart heart--empty"></span>
      </div>
    </div>
  </div>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');

  .health-widget {
    display: inline-block;
    background: #050522;
    border: 4px solid #e8e8e8;
    box-shadow:
      0 0 0 4px #e8e8e8,
      0 0 0 8px #5050cc,
      0 0 0 12px #e8e8e8;
    padding: 22px 32px 26px;
    position: relative;
    image-rendering: pixelated;
    min-width: 260px;
  }

  /* CRT scanlines */
  .health-widget::after {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0px,
      transparent 3px,
      rgba(0, 0, 0, 0.12) 3px,
      rgba(0, 0, 0, 0.12) 4px
    );
    pointer-events: none;
    z-index: 1;
  }

  .widget-inner {
    display: flex;
    flex-direction: column;
    gap: 18px;
    position: relative;
    z-index: 2;
  }

  .widget-name {
    font-family: 'Press Start 2P', monospace;
    font-size: 1rem;
    color: #ffffff;
    margin: 0;
    letter-spacing: 0.06em;
    text-shadow: 2px 2px 0 #000040;
  }

  .hp-row {
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .hp-label {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.7rem;
    color: #ffd700;
    letter-spacing: 0.15em;
    text-shadow: 1px 1px 0 #000040;
  }

  .hearts {
    display: flex;
    gap: 6px;
    align-items: center;
  }

  /* 30×30px layout container; pixel art drawn from ::before (6px origin) */
  .heart {
    display: inline-block;
    width: 30px;
    height: 30px;
    position: relative;
    flex-shrink: 0;
  }

  .heart::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 6px;
    height: 6px;
    background: transparent;
  }

  /* Filled heart — red pixel art, highlight top-left for 3D pop */
  .heart--full::before {
    box-shadow:
      /* row 0 */
       6px  0px 0 #ff2244,  18px  0px 0 #ff2244,
      /* row 1 */
       0px  6px 0 #ff2244,   6px  6px 0 #ff6688,  12px  6px 0 #ff2244,  18px  6px 0 #ff2244,  24px  6px 0 #ff2244,
      /* row 2 */
       0px 12px 0 #ff2244,   6px 12px 0 #ff2244,  12px 12px 0 #ff2244,  18px 12px 0 #ff2244,  24px 12px 0 #ff2244,
      /* row 3 */
       6px 18px 0 #cc1133,  12px 18px 0 #cc1133,  18px 18px 0 #cc1133,
      /* row 4 */
      12px 24px 0 #aa0022;
  }

  /* Empty heart — dark silhouette */
  .heart--empty::before {
    box-shadow:
      /* row 0 */
       6px  0px 0 #3a1828,  18px  0px 0 #3a1828,
      /* row 1 */
       0px  6px 0 #3a1828,   6px  6px 0 #3a1828,  12px  6px 0 #3a1828,  18px  6px 0 #3a1828,  24px  6px 0 #3a1828,
      /* row 2 */
       0px 12px 0 #3a1828,   6px 12px 0 #3a1828,  12px 12px 0 #3a1828,  18px 12px 0 #3a1828,  24px 12px 0 #3a1828,
      /* row 3 */
       6px 18px 0 #3a1828,  12px 18px 0 #3a1828,  18px 18px 0 #3a1828,
      /* row 4 */
      12px 24px 0 #3a1828;
  }

  @media (max-width: 48rem) {
    .health-widget {
      padding: 14px 18px 18px;
      min-width: 0;
    }
    .widget-name {
      font-size: 0.65rem;
    }
    .hp-label {
      font-size: 0.5rem;
    }
    .hp-row {
      gap: 10px;
    }
    .hearts {
      gap: 4px;
    }
    /* Scale hearts from 6px pixels → 4px pixels (container 20×20) */
    .heart {
      width: 20px;
      height: 20px;
    }
    .heart::before {
      width: 4px;
      height: 4px;
    }
    .heart--full::before {
      box-shadow:
        /* row 0 */
         4px  0px 0 #ff2244,  12px  0px 0 #ff2244,
        /* row 1 */
         0px  4px 0 #ff2244,   4px  4px 0 #ff6688,   8px  4px 0 #ff2244,  12px  4px 0 #ff2244,  16px  4px 0 #ff2244,
        /* row 2 */
         0px  8px 0 #ff2244,   4px  8px 0 #ff2244,   8px  8px 0 #ff2244,  12px  8px 0 #ff2244,  16px  8px 0 #ff2244,
        /* row 3 */
         4px 12px 0 #cc1133,   8px 12px 0 #cc1133,  12px 12px 0 #cc1133,
        /* row 4 */
         8px 16px 0 #aa0022;
    }
    .heart--empty::before {
      box-shadow:
        /* row 0 */
         4px  0px 0 #3a1828,  12px  0px 0 #3a1828,
        /* row 1 */
         0px  4px 0 #3a1828,   4px  4px 0 #3a1828,   8px  4px 0 #3a1828,  12px  4px 0 #3a1828,  16px  4px 0 #3a1828,
        /* row 2 */
         0px  8px 0 #3a1828,   4px  8px 0 #3a1828,   8px  8px 0 #3a1828,  12px  8px 0 #3a1828,  16px  8px 0 #3a1828,
        /* row 3 */
         4px 12px 0 #3a1828,   8px 12px 0 #3a1828,  12px 12px 0 #3a1828,
        /* row 4 */
         8px 16px 0 #3a1828;
    }
  }
</style>
