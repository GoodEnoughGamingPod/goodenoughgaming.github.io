<style>
  @import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');

  footer {
    background-color: #13151a;
    border-top: 1px solid rgba(77, 219, 255, 0.12);
  }

  .footer-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 3rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .footer-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .footer-col--right {
    align-items: center;
  }

  .footer-heading {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.9rem;
    color: #4ddbff;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0;
    text-align: center;
    text-shadow: 0 0 10px rgba(77, 219, 255, 0.4);
  }

  .footer-email {
    font-family: 'Raleway', sans-serif;
    font-size: 0.9rem;
    color: #a7a4e0;
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-email:hover {
    color: #4ddbff;
  }

  /* Centre health bar */
  .footer-logo-col {
    flex-shrink: 0;
    display: flex;
    justify-content: center;
  }

  /* Social icons */
  .footer-socials {
    display: flex;
    gap: 0.6rem;
    align-items: center;
  }

  .footer-social-link {
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(167, 164, 224, 0.2);
    display: flex;
    justify-content: center;
    align-items: center;
    color: #a7a4e0;
    text-decoration: none;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }

  .footer-social-link:hover {
    background: rgba(77, 219, 255, 0.15);
    color: #4ddbff;
    border-color: rgba(77, 219, 255, 0.4);
  }

  /* Mobile */
  @media (max-width: 48rem) {
    .footer-inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 2.5rem 1.5rem;
    }

    .footer-col,
    .footer-col--right {
      align-items: center;
    }
  }
</style>
