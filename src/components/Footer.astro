---
import HealthBar from './HealthBar.astro';
---

<footer class="footer">
  <div class="footer-inner">

    <!-- Contact column -->
    <div class="footer-col">
      <h4 class="footer-heading">Contact</h4>
      <a href="mailto:goodenoughgamingpod@gmail.com" class="footer-email">
        goodenoughgamingpod@gmail.com
      </a>
    </div>

    <!-- Health bar (centre) -->
    <div class="footer-logo-col">
      <HealthBar />
    </div>

    <!-- Follow column -->
    <div class="footer-col footer-col--right">
      <h4 class="footer-heading">Follow</h4>
      <div class="footer-socials">

        <a href="https://www.instagram.com/gegpodcast/" class="footer-social-link" aria-label="Instagram" target="_blank" rel="noopener">
          <i class="fa-brands fa-instagram fa-lg"></i>
        </a>

        <a href="https://www.tiktok.com/@goodenoughgamingpod" class="footer-social-link" aria-label="TikTok" target="_blank" rel="noopener">
          <i class="fa-brands fa-tiktok fa-lg"></i>
        </a>

        <a href="https://patreon.com/GoodEnoughGamingPodcast" class="footer-social-link" aria-label="Patreon" target="_blank" rel="noopener">
          <i class="fa-brands fa-patreon fa-lg"></i>
        </a>

        <a href="https://discord.gg/PkNqmbCV" class="footer-social-link" aria-label="Discord" target="_blank" rel="noopener">
          <i class="fa-brands fa-discord fa-lg"></i>
        </a>

        <a href="https://www.youtube.com/@GoodEnoughGamingPod" class="footer-social-link" aria-label="YouTube" target="_blank" rel="noopener">
          <i class="fa-brands fa-youtube fa-lg"></i>
        </a>

      </div>
    </div>

  </div>
</footer>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');

  footer {
    background-color: #13151a;
    border-top: 1px solid rgba(77, 219, 255, 0.12);
  }

  .footer-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 3rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .footer-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .footer-col--right {
    align-items: center;
  }

  .footer-heading {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.9rem;
    color: #4ddbff;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0;
    text-align: center;
    text-shadow: 0 0 10px rgba(77, 219, 255, 0.4);
  }

  .footer-email {
    font-family: 'Raleway', sans-serif;
    font-size: 0.9rem;
    color: #a7a4e0;
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-email:hover {
    color: #4ddbff;
  }

  /* Centre health bar */
  .footer-logo-col {
    flex-shrink: 0;
    display: flex;
    justify-content: center;
  }

  /* Social icons */
  .footer-socials {
    display: flex;
    gap: 1.4rem;
    align-items: center;
  }

  .footer-social-link {
    color: #a7a4e0;
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-social-link:hover {
    color: #4ddbff;
  }

  /* Mobile */
  @media (max-width: 48rem) {
    .footer-inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 2.5rem 1.5rem;
    }

    .footer-col,
    .footer-col--right {
      align-items: center;
    }
  }
</style>
